---

import Container from "../ui/Container.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import PlataformPreview from "./PlataformPreview.astro";

interface Props {
  badge?: string;
  title: string;
  description: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  socialProof?: string;
}

const { badge, title, description, primaryCta, secondaryCta, socialProof = "Mais de 500 devs já se inscreveram na lista de espera", }: Props = Astro.props;

---

<section class="border-b border-border bg-card py-16 md:py-20">
  <Container>
  <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
    <div>
    <Badge>{badge}</Badge>

    <h1 class="mt-6 text-4xl font-bold leading-tight tracking-tight text-text md:text-5xl">
      {title}
    </h1>


    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">

    <Button href={primaryCta.href} variant="primary">
      {primaryCta.label}
    </Button>
    <Button href={secondaryCta.href} variant="outline">
      {secondaryCta.label}
    </Button>

   </div>

   <p class="mt-6 flex items-center gap-2 text-sm text-text-muted">
    <span class="flex -space-x-1" aria-hidden="true">
      <span class="flex h-7 w-7 items-center justify-center rounded-full bg-primary-light text-xs font-bold text-primary">A</span>
      <span class="flex h-7 w-7 items-center justify-center rounded-full bg-slate-200 text-xs font-bold text-text-muted">B</span>
      <span class="flex h-7 w-7 items-center justify-center rounded-full bg-slate-200 text-xs font-bold text-text-muted">C</span>
    </span>
    {socialProof}
  </p>
    </div>

      <PlataformPreview />
    </div>
  </Container>
</section>