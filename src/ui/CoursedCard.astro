---

interface Props {
  href: string;
  badge: string;
  title: string;
  description: string;
  meta?: string;
}

const { href, badge, title, description, meta }: Props = Astro.props;

---

<a href={href} class="group flex h-full flex-col rounded-xl border border-border bg-card p-6 shadow-sm transition hover:border-primary/40 hover:shadow-md">
  <span class="text-xs font-semibold uppercase tracking-wide text-primary">
   {badge}
  </span>
  <h3 class="mt-3 text-xl font-bold text-text group-hover:text-primary">
   {title}
  </h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
   {description}
 </p>
   {
    meta && (
     <p class="mt-4 text-xs font-medium text-text-muted">
      {meta}
     </p>
    )
   }
   <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
    Ver landing <span aria-hidden="true">→</span>
   </span>
</a>