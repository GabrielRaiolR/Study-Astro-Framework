---

interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon }: Props = Astro.props;

---

<article class="rounded-xl border border-border bg-card p-6 shadow-sm">
 {
  icon && (
   <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
    <img src={icon} alt="" class="h-5 w-5 object-contain" aria-hidden="true" />
   </div>
  )
 }
 <h3 class="text-lg font-semibold text-text">
  {title}
 </h3>
 <p class="mt-2 text-sm leading-relaxed text-text-muted">
  {description}
 </p>
</article>