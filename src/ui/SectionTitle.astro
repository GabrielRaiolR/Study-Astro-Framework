---

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" }: Props = Astro.props;

const alignClasses =  align === "center" ? "text-center mx-auto max-w-2xl" : "max-w-2xl";

---

<div class:list={[alignClasses]}>
 {eyebrow && (<p class="text-sm font-semibold uppercase tracking-wider text-primary">
  {eyebrow}
 </p>)}
 <h2 class="mt-2 text-3xl font-bold tracking-tight text-text md:text-4xl">
  {title}
 </h2>
 {
  description && (<p class="mt-4 text-lg leading-relaxed text-text-muted">{description}</p>)
 }
</div>